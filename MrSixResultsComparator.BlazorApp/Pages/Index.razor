    private string FormatSlotType(string slotTypeKey)
    {
        if (int.TryParse(slotTypeKey, out var id) && AlgoIdNames.TryGetValue(id, out var name))
            return $"{name} ({id})";
        return slotTypeKey;
    }

    private List<ComparisonResult> GetSlotFilteredResultsSnapshot()
    {
        var results = StateService.Results.ToList();
        if (string.IsNullOrWhiteSpace(selectedSlotType))
        {
            return results;
        }

        return results
            .Where(r =>
                r.OnlyInControlBySlotType.ContainsKey(selectedSlotType) ||
                r.OnlyInTestBySlotType.ContainsKey(selectedSlotType))
            .ToList();
    }

    private async Task PollAdminStateAsync(CancellationToken cancellationToken)
    {
        await RefreshAdminState(showBusyIndicator: false, clearMessages: false);
        using var timer = new PeriodicTimer(AdminPollInterval);
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshAdminState(showBusyIndicator: false, clearMessages: false);
            }
        }
        catch (OperationCanceledException)
        {
            // Expected during component teardown.
        }
    }

    private async Task RefreshAdminState()
    {
        await RefreshAdminState(showBusyIndicator: true, clearMessages: true);
    }

    private async Task RefreshAdminState(bool showBusyIndicator, bool clearMessages)
    {
        if (!showBusyIndicator && isAdminBusy)
        {
            return;
        }

        try
        {
            if (showBusyIndicator)
            {
                isAdminBusy = true;
                if (clearMessages)
                {
                    adminError = null;
                    adminMessage = null;
                }

                await InvokeAsync(StateHasChanged);
            }

            var controlTask = AdminControlService.GetServerState(ServerTarget.Control);
            var testTask = AdminControlService.GetServerState(ServerTarget.Test);
            await Task.WhenAll(controlTask, testTask);

            controlAdminState = controlTask.Result;
            testAdminState = testTask.Result;
            TryAutoHideRestartMessage();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            controlAdminState ??= ServerAdminState.Failed("Control", ex.Message);
            testAdminState ??= ServerAdminState.Failed("Test", ex.Message);
            if (showBusyIndicator)
            {
                adminError = $"Failed to refresh server status: {ex.Message}";
            }

            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            if (showBusyIndicator)
            {
                isAdminBusy = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private static bool IsReadyState(string? readiness) =>
        string.Equals(readiness, "Ready", StringComparison.OrdinalIgnoreCase);

    private void TryAutoHideRestartMessage()
    {
        if (!shouldAutoHideRestartMessage)
        {
            return;
        }

        var controlInRestartTransition = IsHydratingOrRunningState(controlAdminState?.Readiness);
        var testInRestartTransition = IsHydratingOrRunningState(testAdminState?.Readiness);
        if (controlInRestartTransition && testInRestartTransition)
        {
            shouldAutoHideRestartMessage = false;
            adminMessage = null;
        }
    }

    private static bool IsHydratingOrRunningState(string? readiness) =>
        string.Equals(readiness, "Hydrating", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(readiness, "Running", StringComparison.OrdinalIgnoreCase);

    private static string GetReadinessStyle(string readiness)
    {
        return readiness switch
        {
            "Ready" => "color: #166534; font-weight: 700;",
            "Hydrating" => "color: #92400e; font-weight: 700;",
            "NotRunning" => "color: #991b1b; font-weight: 700;",
            _ => "color: #475569; font-weight: 700;"
        };
    }

    private static string GetRuntimeStatus(ServerAdminState state) =>
        state.ProcessRunning ? "Running" : "Not running";

    public void Dispose()
    {
        StateService.StateChanged -= OnStateChanged;
        _cts?.Cancel();
        _cts?.Dispose();
        _adminPollingCts?.Cancel();
        _adminPollingCts?.Dispose();
    }
